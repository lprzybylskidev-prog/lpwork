APP_ENV=development
APP_NAME=LPWork
APP_DEBUG=true
APP_URL=http://localhost
APP_LANG=en_US
APP_TIMEZONE=UTC
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

ERROR_LOG_DIRECTORY='/storage/logs'
ERROR_REPORTING=30719
ERROR_DISPLAY=0
ERROR_DISPLAY_STARTUP=0
ERROR_LOG=1

DB_CONNECTION=sqlite
DB_MYSQL_HOST=mysql
DB_MYSQL_PORT=3306
DB_MYSQL_DATABASE=lpwork
DB_MYSQL_USERNAME=lpwork
DB_MYSQL_PASSWORD=lpwork
DB_MYSQL_CHARSET=utf8mb4
DB_PGSQL_HOST=database
DB_PGSQL_PORT=5432
DB_PGSQL_DATABASE=lpwork
DB_PGSQL_USERNAME=lpwork
DB_PGSQL_PASSWORD=lpwork
DB_PGSQL_CHARSET=utf8
DB_SQLITE_DATABASE=storage/database.sqlite
DB_LOG_QUERIES=false
DB_LOG_CHANNEL=app
DB_LOG_LEVEL=debug

CACHE_STORE=framework
CACHE_REDIS_HOST=redis
CACHE_REDIS_PORT=6379
CACHE_REDIS_PASSWORD=
CACHE_REDIS_DATABASE=0
CACHE_REDIS_TIMEOUT_SECONDS=2.5
CACHE_REDIS_PREFIX=lpwork:cache:
CACHE_DATABASE_CONNECTION=
CACHE_DATABASE_TABLE=cache_entries
CACHE_APCU_PREFIX=lpwork:

STORAGE_DISK=local
STORAGE_S3_BUCKET=lpwork
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=test
STORAGE_S3_SECRET_KEY=test
STORAGE_S3_ENDPOINT=http://localstack:4566
STORAGE_S3_PATH_STYLE=true
STORAGE_FTP_HOST=127.0.0.1
STORAGE_FTP_PORT=21
STORAGE_FTP_USERNAME=
STORAGE_FTP_PASSWORD=
STORAGE_FTP_ROOT=
STORAGE_FTP_TIMEOUT_SECONDS=30
STORAGE_FTP_SSL=false
STORAGE_FTP_PASSIVE=true
STORAGE_SFTP_HOST=127.0.0.1
STORAGE_SFTP_PORT=22
STORAGE_SFTP_USERNAME=
STORAGE_SFTP_PASSWORD=
STORAGE_SFTP_ROOT=
STORAGE_SFTP_TIMEOUT_SECONDS=30

MAIL_TRANSPORT=log
MAIL_FROM=app
MAIL_FROM_ADDRESS=hello@example.test
MAIL_FROM_NAME="LPWork App"
MAIL_SUPPORT_ADDRESS=support@example.test
MAIL_SUPPORT_NAME="LPWork Support"
MAIL_SMTP_HOST=mailpit
MAIL_SMTP_PORT=1025
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_ENCRYPTION=
MAIL_SMTP_TIMEOUT_SECONDS=30
MAIL_SENDMAIL_COMMAND="/usr/sbin/sendmail -t -i"
MAIL_SES_REGION=us-east-1
MAIL_SES_ACCESS_KEY=
MAIL_SES_SECRET_KEY=
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=https://api.mailgun.net
MAIL_LOG_ENABLED=true
MAIL_LOG_CHANNEL=app
MAIL_LOG_LEVEL=info

QUEUE_CONNECTION=sync
QUEUE_NAME=default
QUEUE_MAX_ATTEMPTS=3
QUEUE_RETRY_AFTER_SECONDS=90
QUEUE_RETRY_DELAY_SECONDS=5
QUEUE_COMPLETED_RETENTION_SECONDS=604800
QUEUE_FAILED_RETENTION_SECONDS=2592000
QUEUE_DATABASE_CONNECTION=
QUEUE_DATABASE_TABLE=queue_jobs
QUEUE_REDIS_HOST=redis
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DATABASE=0
QUEUE_REDIS_TIMEOUT_SECONDS=2.5
QUEUE_REDIS_PREFIX=lpwork:queue:
QUEUE_SQS_URL=http://localstack:4566/000000000000/lpwork
QUEUE_SQS_REGION=us-east-1
QUEUE_SQS_ACCESS_KEY=test
QUEUE_SQS_SECRET_KEY=test

SCHEDULE_LOCK_TTL_SECONDS=900
SCHEDULE_DATABASE_CONNECTION=sqlite
SCHEDULE_LOCKS_TABLE=schedule_locks
SCHEDULE_RUNS_TABLE=schedule_runs
SCHEDULE_HISTORY_ENABLED=true
SCHEDULE_HISTORY_RETENTION_SECONDS=2592000

SESSION_DRIVER=php
SESSION_NAME=LPWORK_SESSION
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax
SESSION_USE_STRICT_MODE=true
SESSION_CACHE_STORE=framework
SESSION_DATABASE_CONNECTION=
SESSION_DATABASE_TABLE=sessions
SESSION_REDIS_HOST=redis
SESSION_REDIS_PORT=6379
SESSION_REDIS_PASSWORD=
SESSION_REDIS_DATABASE=0
SESSION_REDIS_TIMEOUT_SECONDS=2.5
SESSION_REDIS_PREFIX=lpwork:session:

LOCK_DRIVER=cache
LOCK_STORE=framework
LOCK_TTL_SECONDS=900
LOCK_DATABASE_CONNECTION=
LOCK_DATABASE_TABLE=locks
LOCK_REDIS_HOST=redis
LOCK_REDIS_PORT=6379
LOCK_REDIS_PASSWORD=
LOCK_REDIS_DATABASE=0
LOCK_REDIS_TIMEOUT_SECONDS=2.5
LOCK_REDIS_PREFIX=lpwork:locks:

BROADCAST_CONNECTION=log
BROADCAST_LOG_CHANNEL=app
BROADCAST_REDIS_HOST=redis
BROADCAST_REDIS_PORT=6379
BROADCAST_REDIS_PASSWORD=
BROADCAST_REDIS_DATABASE=0
BROADCAST_REDIS_TIMEOUT_SECONDS=2.5
BROADCAST_REDIS_PREFIX=lpwork:broadcast:
PUSHER_APP_ID=lpwork
PUSHER_APP_KEY=lpwork-key
PUSHER_APP_SECRET=lpwork-secret
PUSHER_ENDPOINT=http://soketi:6001

METRICS_REPORTERS=null
METRICS_MEMORY_LIMIT=100
METRICS_PROMETHEUS_PATH=storage/metrics/prometheus.prom
METRICS_STATSD_HOST=statsd
METRICS_STATSD_PORT=9125
METRICS_STATSD_PREFIX=lpwork

SECURITY_ENFORCE_HTTPS=false
SECURITY_SEND_HEADERS=false
SECURITY_SECURE_COOKIES=false
SECURITY_MAX_REQUEST_BODY_BYTES=10485760
SECURITY_MAX_UPLOAD_BYTES=10485760
SECURITY_CSRF_ENABLED=false

THROTTLE_STORAGE=memory
THROTTLE_CACHE_STORE=framework
THROTTLE_HTTP_WEB_ENABLED=false
THROTTLE_HTTP_WEB_MAX_ATTEMPTS=60
THROTTLE_HTTP_WEB_DECAY_SECONDS=60
THROTTLE_HTTP_API_ENABLED=false
THROTTLE_HTTP_API_MAX_ATTEMPTS=60
THROTTLE_HTTP_API_DECAY_SECONDS=60
THROTTLE_CLI_ENABLED=false
THROTTLE_CLI_MAX_ATTEMPTS=60
THROTTLE_CLI_DECAY_SECONDS=60
