{
  "name": "lpwork/framework",
  "description": "Personal PHP framework learning project.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.5",
    "fakerphp/faker": "^1.24"
  },
  "require-dev": {
    "ergebnis/phpstan-rules": "^2.8",
    "friendsofphp/php-cs-fixer": "^3.79",
    "pestphp/pest": "^4.7",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-strict-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "LPWork\\": "LPWork/",
      "App\\": "App/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\support\\": "LPWork/TestSupport/"
    }
  },
  "bin": [
    "lpwork"
  ],
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
